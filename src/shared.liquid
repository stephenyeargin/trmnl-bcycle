<div class="item">
  <div class="meta"></div>
  <div class="content">
    <span class="label label--base lg:label--lg label--underline" data-clamp="1"><b>{{ station.name }}</b></span>
    <span class="description description--small lg:description--base text--gray-3 hidden lg:block" data-clamp="1">{{ station.address }}</span>
    <div class="flex flex--row gap gap--sm">
      <div>
        <img class="image h--6" src="data:image/svg+xml;base64,{{ svg_bike | base64_encode }}" />
      </div>
      <div class="pr--1 text--center">
        {%- if station.is_renting and station.is_installed %}
        <span class="label label--base lg:label--lg">{{ station.num_bikes_available }}</span>
        {%- else -%}
        <span class="label label--base lg:label--lg label--inverted">⚠︎ Offline</span>
        {%- endif %}
      </div>
      <div>
        <img class="image h--6" src="data:image/svg+xml;base64,{{ svg_dock | base64_encode }}" />
      </div>
      <div class="pr--1 text--center">
        {%- if station.is_returning and station.is_installed %}
        <span class="label label--base lg:label--lg">{{ station.num_docks_available }}</span>
        {%- else -%}
        <span class="label label--base lg:label--lg label--inverted">⚠︎ Offline</span>
        {%- endif %}
      </div>
    </div>
  </div>
</div>
{% endtemplate %}
